{
  "name": "medicheck-system",
  "version": "1.0.0",
  "description": "MediCheck Medical Diagnosis Expert System — backend API with Prolog inference engine",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node src/server.ts",
    "db:init": "ts-node src/scripts/initDb.ts",
    "test": "jest",
    "test:unit": "jest --testPathPattern='src/tests/unit'",
    "test:integration": "jest --testPathPattern='src/tests/integration'",
    "test:expert": "jest --testPathPattern='src/tests/expert-system'",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch"
  },
  "packageManager": "pnpm@9.0.0",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "pg": "^8.11.5",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.12",
    "@types/pg": "^8.11.6",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.8",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
